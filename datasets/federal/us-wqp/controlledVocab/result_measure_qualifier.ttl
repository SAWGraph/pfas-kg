us_wqp:resultMeasureQualifier.QC a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier QC"^^xsd:string ;
    rdfs:comment "Quality Control problems"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.QCI a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier QCI"^^xsd:string ;
    rdfs:comment "Quality Control incomplete"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.R a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier R"^^xsd:string ;
    rdfs:comment "Rejected: The sample results are unusable due to the quality of the data generated because certain criteria were not met. The analyte may or may not be present in the sample. "^^xsd:string ;
