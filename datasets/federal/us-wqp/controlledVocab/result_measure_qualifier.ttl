    rdfs:label "Result Measure Qualifier CKB"^^xsd:string ;
    rdfs:comment "CC PK B; Co-eluting congener, peak detected but did not meet quantification criteria (result reported represents the estimated maximum possible concentration) and analyte found in sample and associated blank"^^xsd:string ;
