us_wqp:resultMeasureQualifier.RR a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RR"^^xsd:string ;
    rdfs:comment "Lab reported a result value"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RV a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RV"^^xsd:string ;
    rdfs:comment "Results are within precision limits and are analytically equal."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RVB a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RVB"^^xsd:string ;
    rdfs:comment "Result Value Between"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.S2 a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier S2"^^xsd:string ;
    rdfs:comment "Shipping time exceeded two day limit"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SBB a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SBB"^^xsd:string ;
    rdfs:comment "Estimated Value, less than blank"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SCA a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SCA"^^xsd:string ;
    rdfs:comment "Suspected Contamination, lab analysis"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SCF a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SCF"^^xsd:string ;
    rdfs:comment "Suspected Contamination, field"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SCP a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SCP"^^xsd:string ;
    rdfs:comment "Suspected Contamination, lab preparation"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SCX a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SCX"^^xsd:string ;
    rdfs:comment "Suspected Contamination, unknown"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SD%25EL a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SD%EL"^^xsd:string ;
    rdfs:comment "MS/MSD RPD exceeds control limits"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SDROL a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SDROL"^^xsd:string ;
    rdfs:comment "MS and/or MSD Recovery is outside acceptance limits"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SLB a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SLB"^^xsd:string ;
    rdfs:comment "Spike level low compared to background"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SM a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SM"^^xsd:string ;
    rdfs:comment "same method (USGS)"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SS a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SS"^^xsd:string ;
    rdfs:comment "Sample size difference"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SSR a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SSR"^^xsd:string ;
    rdfs:comment "Surrogate standard acceptance criteria not met"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SSRV a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SSRV"^^xsd:string ;
    rdfs:comment "Surrogate or spike recovery value associated with sample analyte or analytes"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.SUS a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier SUS"^^xsd:string ;
    rdfs:comment "Result value is defined as suspect by data owner. (HV) High variability: questionable precision and accuracy"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.T a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier T"^^xsd:string ;
    rdfs:comment "Hardness by Calculation Method - Standard Methods 2340B - 19th Ed "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.T5 a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier T5"^^xsd:string ;
    rdfs:comment "Laboratory not licensed for this parameter"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.TMLF a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier TMLF"^^xsd:string ;
    rdfs:comment "Time missing in logger file."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.TOC a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier TOC"^^xsd:string ;
    rdfs:comment "Temperature outside of criteria"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.TR a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier TR"^^xsd:string ;
    rdfs:comment "Trace"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.TT a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier TT"^^xsd:string ;
    rdfs:comment "analyte recalculated against alternate labeled compound(s)"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.U a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier U"^^xsd:string ;
    rdfs:comment "Not Detected: The analyte was analyzed for, but was not detected at a level greater than or equal to the level of the adjusted Contract Required Quantitation Limit (CRQL) for sample and method. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.UDL a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier UDL"^^xsd:string ;
    rdfs:comment "Lab's detection limit is not known/available for validation or comparison to the result."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.UDQ a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier UDQ"^^xsd:string ;
    rdfs:comment "Lab's detection limit not known/available for comparison to the result; however with parameter specific evaluation determined to be quantified."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.UNC a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier UNC"^^xsd:string ;
    rdfs:comment "Value Not Confirmed"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.V a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier V"^^xsd:string ;
    rdfs:comment "Surrogate recoveries out of range"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.V1 a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier V1"^^xsd:string ;
    rdfs:comment "Continuing calibration verification (CCV) recovery was above method acceptance limits"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.VS a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier VS"^^xsd:string ;
    rdfs:comment "compound identified verified by 2nd method"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.VVRR a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier VVRR"^^xsd:string ;
    rdfs:comment "Value verified by rerun"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.VVRR2 a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier VVRR2"^^xsd:string ;
    rdfs:comment "value verified by rerun, 2nd method"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.ZZ a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier ZZ"^^xsd:string ;
    rdfs:comment "Blank-corrected data were indicated by the \"Z\" qualifier code. The laboratory reported the concentration of analyte to the nearest unit. These data were qualified as blank-corrected and as undetected when the blank correction resulted in a concentration below the DL."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.nan a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier nan"^^xsd:string ;
    rdfs:comment "Not Applicable"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp_cv:result_measure_qualifier a owl:Ontology ;
    dcterms:description "This ontology contains the controlled vocabulary for Result Measure Qualifier from the Water Quality Portal"^^xsd:string ;
    dcterms:modified "2026-04-22"^^xsd:date ;
    dcterms:title "WQP Controlled Vocabulary - Result Measure Qualifier"^^xsd:string .

