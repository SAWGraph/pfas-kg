    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.PRE a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier PRE"^^xsd:string ;
    rdfs:comment "Presumptive evidence that analyte is present."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.Q a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier Q"^^xsd:string ;
    rdfs:comment "The result did not pass the lab quality checks and there was an insufficient amount of the sample for re-analysis."^^xsd:string ;
