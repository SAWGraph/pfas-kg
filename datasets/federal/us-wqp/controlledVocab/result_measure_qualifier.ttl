us_wqp:resultMeasureQualifier.RA a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RA"^^xsd:string ;
    rdfs:comment "Results fall outside the normal limits of variability and do not meet Data Quality Objectives. Reanalyses were performed with consistent results. All QA "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RC a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RC"^^xsd:string ;
    rdfs:comment "See result comment"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.REX a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier REX"^^xsd:string ;
    rdfs:comment "Re-Prepared"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RIN a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RIN"^^xsd:string ;
    rdfs:comment "Re-Analyzed"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RLRS a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RLRS"^^xsd:string ;
    rdfs:comment "Reporting limit raised, low total solids"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RMAX a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RMAX"^^xsd:string ;
    rdfs:comment "result is a maximum value"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RNAF a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RNAF"^^xsd:string ;
    rdfs:comment "result not affected by noted QC issue"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:result_measure_qualifier .

us_wqp:resultMeasureQualifier.RNON a us_wqp:ResultMeasureQualifier ;
    rdfs:label "Result Measure Qualifier RNON"^^xsd:string ;
    rdfs:comment "result reported as non-detect due to blank contamination"^^xsd:string ;
