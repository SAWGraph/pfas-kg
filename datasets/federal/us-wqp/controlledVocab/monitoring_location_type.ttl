@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix us_wqp: <http://w3id.org/sawgraph/v1/us-wqp#> .
@prefix us_wqp_cv: <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

us_wqp:featureType.Atmosphere a us_wqp:LocationType ;
    rdfs:label "Atmosphere" ;
    rdfs:comment "Atmosphere monitoring stations provide weather data about conditions"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteChannelizedstream a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Channelized stream" ;
    rdfs:comment "The process of straightening or redirecting natural streams in an artificially modified or constructed stream bed. Channelization has been carried out for numerous reasons, most often to drain wetlands , direct water flow for agricultural use, and control flooding . While this process makes a stream more useful for human activities, it tends to interfere with natural river habitats and to destabilize stream banks by destroying riparian vegetation."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteEstuary a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Estuary" ;
    rdfs:comment """a partially enclosed coastal body of brackish water with one or more rivers or streams flowing into it, and with a free connection to the open sea
Estuaries form a transition zone between river environments and maritime environments. 
The sea water entering the estuary is diluted by the fresh water flowing from rivers and streams.
"""^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteGreatLake a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Great Lake" ;
    rdfs:comment "The Great Lakes, also called the Laurentian Great Lakes and the Great Lakes of North America, are a series of interconnected freshwater lakes primarily in the upper mid-east region of North America, on the Canada–United States border, which connect to the Atlantic Ocean through the Saint Lawrence River."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteLake a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Lake" ;
    rdfs:comment "A lake is an area filled with water, localized in a basin, that is surrounded by land, apart from any river or other outlet that serves to feed or drain the lake"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteLand a us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Land" ;
    rdfs:comment "Land, sometimes referred to as dry land, is the solid surface of Earth that is not permanently covered by water."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteLandrunoff a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Land runoff" ;
    rdfs:comment "Also known as overland flow is the flow of water that occurs when excess stormwater, meltwater, or other sources flows over the Earth's surface."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteOcean a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Ocean" ;
    rdfs:comment "An ocean is a body of water that composes much of a planet's hydrosphere."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteRiverStream a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-River/Stream" ;
    rdfs:comment "A river is a natural flowing watercourse, usually freshwater, flowing towards an ocean, sea, lake or another river. In some cases a river flows into the ground and becomes dry at the end of its course without reaching another body of water. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteStormsewer a us_wqp:DefWQPWasteWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Storm sewer" ;
    rdfs:comment "The storm sewer is a system designed to carry rainfall runoff and other drainage."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.BEACHProgramSiteWastesewer a us_wqp:DefWQPWasteWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "BEACH Program Site-Waste sewer" ;
    rdfs:comment "The wastewater from residences and institutions, carrying bodily wastes (primarily feces and urine), washing water, food preparation wastes, laundry wastes, and other waste products of normal living, are classed as domestic or sanitary sewage."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Borehole a us_wqp:DefWQPGroundWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Borehole" ;
    rdfs:comment "A borehole is a narrow shaft bored in the ground, either vertically or horizontally. A borehole may be constructed for many different purposes, including the extraction of water, other liquids (such as petroleum) or gases (such as natural gas), as part of a geotechnical investigation, environmental site assessment,"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.CERCLASuperfundSite a us_wqp:LocationType ;
    rdfs:label "CERCLA Superfund Site" ;
    rdfs:comment "The Superfund site assessment process evaluates potential or confirmed releases of hazardous substances that may pose a threat to human health or the environment using the Hazard Ranking System (HRS) criteria guide"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.CanalDrainage a us_wqp:LocationType ;
    rdfs:label "Canal Drainage" ;
    rdfs:comment "As a channel drainage system it is designed to eliminate the need for further pipework systems to be installed in parallel to the drainage, reducing the environmental impact of production as well as improving water collection."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.CanalIrrigation a us_wqp:LocationType ;
    rdfs:label "Canal Irrigation" ;
    rdfs:comment "Irrigation canals are the main waterways that bring irrigation water from a water source to the areas to be irrigated. They can be lined with concrete, brick, stone, or a flexible membrane to prevent seepage and erosion."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.CanalTransport a us_wqp:LocationType ;
    rdfs:label "Canal Transport" ;
    rdfs:comment "Canals are human-made channels for water conveyance, or to service water transport vehicles. In most cases, the engineered works will have a series of dams and locks that create areas of low speed current flow. These areas are referred to as slack water levels, often just called levels."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Cave a us_wqp:LocationType ;
    rdfs:label "Cave" ;
    rdfs:comment "A cave is a hollow place in the ground, specifically a natural underground space large enough for a human to enter. Caves form naturally by the weathering of rock and often extend deep underground. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.ChannelizedStream a us_wqp:LocationType ;
    rdfs:label "Channelized Stream" ;
    rdfs:comment "The process of straightening or redirecting natural streams in an artificially modified or constructed stream bed. Channelization has been carried out for numerous reasons, most often to drain wetlands , direct water flow for agricultural use, and control flooding . While this process makes a stream more useful for human activities, it tends to interfere with natural river habitats and to destabilize stream banks by destroying riparian vegetation."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.CombinedSewer a us_wqp:LocationType ;
    rdfs:label "Combined Sewer" ;
    rdfs:comment "A combined sewer system (CSS) collects rainwater runoff, domestic sewage, and industrial wastewater into one pipe. Under normal conditions, it transports all of the wastewater it collects to a sewage treatment plant for treatment, then discharges to a water body. Combined sewer overflows (CSOs) contain untreated or partially treated human and industrial waste, toxic materials, and debris as well as stormwater."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.ConstructedDiversionDam a us_wqp:LocationType ;
    rdfs:label "Constructed Diversion Dam" ;
    rdfs:comment "A diversion dam is a dam that diverts all or a portion of the flow of a river from its natural course. Diversion dams do not generally impound water in a reservoir. Instead, the water is diverted into an artificial water course or canal, which may be used for irrigation or return to the river after passing through hydroelectric generators, flow into a different river or be itself dammed forming a reservoir."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.ConstructedTunnel a us_wqp:LocationType ;
    rdfs:label "Constructed Tunnel" ;
    rdfs:comment "an artificial underground passage, especially one built through a hill or under a building, road, or river."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.ConstructedWaterTransportStructure a us_wqp:LocationType ;
    rdfs:label "Constructed Water Transport Structure" ;
    rdfs:comment "a system of structures and measures that support the  intentional movement of water over large distances. simple aqueducts to transport water above ground level. short pipelines to transport water above or under another structure such as a water canal or an access road"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.ConstructedWetland a us_wqp:LocationType ;
    rdfs:label "Constructed Wetland" ;
    rdfs:comment "A constructed wetland (CW) is an artificial wetland to treat municipal or industrial wastewater, greywater or stormwater runoff. It may also be designed for land reclamation after mining, or as a mitigation step for natural areas lost to land development.Constructed wetlands are engineered systems that use natural functions vegetation, soil, and organisms to treat wastewater"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Estuary a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Estuary" ;
    rdfs:comment """a partially enclosed coastal body of brackish water with one or more rivers or streams flowing into it, and with a free connection to the open sea\r
Estuaries form a transition zone between river environments and maritime environments. \r
The sea water entering the estuary is diluted by the fresh water flowing from rivers and streams.\r
"""^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.EstuaryFreshwater a us_wqp:LocationType ;
    rdfs:label "Estuary-Freshwater" ;
    rdfs:comment "Freshwater estuaries are semi-enclosed areas of the Great Lakes in which lake and river water mix, forming a transition zone between river and lake environments that are chemically distinct"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FacilityIndustrial a us_wqp:LocationType ;
    rdfs:label "Facility Industrial" ;
    rdfs:comment "a facility composed of one or more pieces of equipment connected to or part of a structure and designed to provide a service such as heat or electricity or water or sewage disposal. \"the price of the house included all utilities"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FacilityMunicipalSewagePOTW a us_wqp:DefWQPWasteWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Facility Municipal Sewage (POTW)" ;
    rdfs:comment "Treatment works treating domestic sewage means a POTW or any other sewage sludge or waste water treatment devices or systems, regardless of ownership (including federal facilities), used in the storage, treatment, recycling, and reclamation of municipal or domestic sewage, including land dedicated for the disposal of sewage sludge. This definition does not include septic tanks or similar devices."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FacilityOther a us_wqp:LocationType ;
    rdfs:label "Facility Other" ;
    rdfs:comment "a facility composed of one or more pieces of equipment connected to or part of a structure and designed to provide a service such as Reclaimed water can supply needed water for some purposes Reclaimed wastewater frees up fresh water that can be used somewhere else, such as for drinking water"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FacilityPrivatelyOwnedNonindustrial a us_wqp:LocationType ;
    rdfs:label "Facility Privately Owned Non-industrial" ;
    rdfs:comment "Privately owned treatment works means any device or system which is (a) used to treat wastes from any facility whose operator is not the operator of the treatment works"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FacilityPublicWaterSupplyPWS a us_wqp:LocationType ;
    rdfs:label "Facility Public Water Supply (PWS)" ;
    rdfs:comment """A Public Water System is a public water supply for the provision to the public of piped water for human consumption, A Public Water System includes any collection, treatment, storage,
and distribution facilities under control of such system, including the operator or administrator of such system, and is used primarily in
connection with such system and any collection or pretreatment storage facilities not under such control which are used primarily in
connection with such system.”"""^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FloodwaterUrban a us_wqp:LocationType ;
    rdfs:label "Floodwater Urban" ;
    rdfs:comment "A flood is an overflow of water that submerges land that is usually dry  In the sense of \"urban runoff water\". it may occur due to an accumulation of rainwater on saturated ground in an areal flood."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.FloodwaternonUrban a us_wqp:LocationType ;
    rdfs:label "Floodwater non-Urban" ;
    rdfs:comment "A flood is an overflow of water that submerges land that is usually dry  Flooding may occur as an overflow of water from water bodies, such as a river, lake, or ocean, in which the water overtops or breaks levees, resulting in some of that water escaping its usual boundaries"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Gallery a us_wqp:LocationType ;
    rdfs:label "Gallery" ;
    rdfs:comment "An infiltration gallery is a structure including perforated conduits in gravel to expedite transfer of water to or from a soil."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasCondensate a us_wqp:LocationType ;
    rdfs:label "Gas-Condensate" ;
    rdfs:comment "Natural-gas condensate, also called natural gas liquids, is a low-density mixture of hydrocarbon liquids that are present as gaseous components in the raw natural gas produced from many natural gas fields. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasEngine a us_wqp:LocationType ;
    rdfs:label "Gas-Engine" ;
    rdfs:comment "A gas engine is an internal combustion engine that runs on a gaseous fuel, such as coal gas, producer gas, biogas, landfill gas or natural gas."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasExtraction a us_wqp:LocationType ;
    rdfs:label "Gas-Extraction" ;
    rdfs:comment "Oil and Gas Extraction is the exploration and production of petroleum and natural gas from wells. The industry generates wastewater from the water extracted from the geological formations and from chemicals used during exploration, well drilling and production of oil and gas."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasFlare a us_wqp:LocationType ;
    rdfs:label "Gas-Flare" ;
    rdfs:comment "A gas flare, alternatively known as a flare stack, is a gas combustion device used in industrial plants such as petroleum refineries, chemical plants, natural gas processing plants as well as at oil or gas production sites having oil wells, gas wells, offshore oil and gas rigs and landfills."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasMonitoringProbe a us_wqp:LocationType ;
    rdfs:label "Gas-Monitoring Probe" ;
    rdfs:comment """Gas monitoring probes are used to enhance environmental protection at landfills. Gas
concentrations are measured at permit or regulatory specified time intervals. This process
allows potential environmental concerns to be identified early, evaluated and corrected
(when necessary) in accordance with regulations and sound scientific approaches."""^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasPassiveVent a us_wqp:LocationType ;
    rdfs:label "Gas-Passive Vent" ;
    rdfs:comment "Dispersion of gas safely from soil."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasSubslab a us_wqp:LocationType ;
    rdfs:label "Gas-Subslab" ;
    rdfs:comment "Sub-slab Soil Gas: Sub-slab samples are collected to characterize the nature and extent of vapor contamination in the soil immediately beneath a building with a slab or beneath the basement floor."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GasTemporary a us_wqp:LocationType ;
    rdfs:label "Gas-Temporary" ;
    rdfs:comment "a gas capable of liquefaction"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.GreatLake a us_wqp:LocationType ;
    rdfs:label "Great Lake" ;
    rdfs:comment "The Great Lakes, also called the Laurentian Great Lakes and the Great Lakes of North America, are a series of interconnected freshwater lakes primarily in the upper mid-east region of North America, on the Canada–United States border, which connect to the Atlantic Ocean through the Saint Lawrence River."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Intertidal a us_wqp:LocationType ;
    rdfs:label "Intertidal" ;
    rdfs:comment "denoting the area of a seashore which is covered at high tide and uncovered at low tide"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Lake a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Lake" ;
    rdfs:comment "A lake is an area filled with water, localized in a basin, that is surrounded by land, apart from any river or other outlet that serves to feed or drain the lake"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Land a us_wqp:LocationType ;
    rdfs:label "Land" ;
    rdfs:comment "Land, sometimes referred to as dry land, is the solid surface of Earth that is not permanently covered by water."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LandFloodPlain a us_wqp:LocationType ;
    rdfs:label "Land Flood Plain" ;
    rdfs:comment "An area of land adjacent to a stream or river which stretches from the banks of its channel to the base of the enclosing valley walls, and which experiences flooding during periods of high discharge."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LandRunoff a us_wqp:LocationType ;
    rdfs:label "Land Runoff" ;
    rdfs:comment "Also known as overland flow is the flow of water that occurs when excess stormwater, meltwater, or other sources flows over the Earth's surface."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Landfill a us_wqp:LocationType ;
    rdfs:label "Landfill" ;
    rdfs:comment "A site for the disposal of waste materials by burial."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LeachateExtraction a us_wqp:LocationType ;
    rdfs:label "Leachate-Extraction" ;
    rdfs:comment "The pump systems which extract the leachate from the wastes"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LeachateHeadWell a us_wqp:LocationType ;
    rdfs:label "Leachate-Head Well" ;
    rdfs:comment "The wells and boreholes within the landfill into which the leachate collection system conveys the leachate. The well head where samples of water are taken determining water quality in source Leachate"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LeachateLysimeter a us_wqp:LocationType ;
    rdfs:label "Leachate-Lysimeter" ;
    rdfs:comment "Is a measuring device which can be used to measure the amount of actual evapotranspiration which is released by plants (usually crops or trees)"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LeachateSamplePoint a us_wqp:LocationType ;
    rdfs:label "Leachate-SamplePoint" ;
    rdfs:comment "The point where samples of water are taken determining water quality in source the pipes/pipelines which convey the leachate to the collection tank, or treatment plant location. Leachate is the liquid that drains or 'leaches' from a landfill. It varies widely in composition regarding the age of the landfill and the type of waste that it contains. It usually contains both dissolved and suspended material."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.LocalAirMonitoringStation a us_wqp:LocationType ;
    rdfs:label "Local Air Monitoring Station" ;
    rdfs:comment "Ambient air monitoring is the systematic, long-term assessment of pollutant levels by measuring the quantity and types of certain pollutants in the surrounding, outdoor air."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.MineMineDischarge a us_wqp:LocationType ;
    rdfs:label "Mine/Mine Discharge" ;
    rdfs:comment "Formed when pyrite (an iron sulfide) is exposed and reacts with air and water to form sulfuric acid and dissolved iron. Some or all of this iron can precipitate to form the red, orange, or yellow sediments in the bottom of streams containing mine drainage. The acid runoff further dissolves heavy metals such as copper, lead, and mercury into groundwater or surface water. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.MineMineDischargeAditMineEntrance a us_wqp:LocationType ;
    rdfs:label "Mine/Mine Discharge Adit (Mine Entrance)" ;
    rdfs:comment "An adit (from Latin aditus, entrance) is an entrance to an underground mine which is horizontal or nearly horizontal, by which the mine can be entered, drained of water, ventilated, and minerals extracted at the lowest convenient level."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.MineMineDischargeTailingsPile a us_wqp:LocationType ;
    rdfs:label "Mine/Mine Discharge Tailings Pile" ;
    rdfs:comment "Materials left over after the process of separating the valuable fraction from the uneconomic fraction (gangue) of an ore. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.MineMineDischargeWasteRockPile a us_wqp:LocationType ;
    rdfs:label "Mine/Mine Discharge Waste Rock Pile" ;
    rdfs:comment "Mine drainage is metal-rich water formed from chemical reaction between water and rocks containing. sulfur-bearing minerals. • The runoff formed is usually acidic and frequently comes from areas where ore or coal mining activities. have exposed rocks containing pyrite, a sulfur bearing mineral"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.MinePit a us_wqp:LocationType ;
    rdfs:label "Mine Pit" ;
    rdfs:comment "Open-pit mining, also known as opencast mining, is a surface mining technique that extracts minerals from an open pit in the ground. Open-pits are sometimes called ‘quarries’ when they produce building materials and dimension stone."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.NationalAirMonitoringStation a us_wqp:LocationType ;
    rdfs:label "National Air Monitoring Station" ;
    rdfs:comment "Ambient air monitoring is the systematic, long-term assessment of pollutant levels by measuring the quantity and types of certain pollutants in the surrounding, outdoor air."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Ocean a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Ocean" ;
    rdfs:comment "An ocean is a body of water that composes much of a planet's hydrosphere."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.OilandGasWell a us_wqp:LocationType ;
    rdfs:label "Oil and Gas Well" ;
    rdfs:comment "An oil well is a boring in the Earth that is designed to bring petroleum oil hydrocarbons to the surface. Usually some natural gas is released along with the oil. A well that is designed to produce only gas may be termed a gas well."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.OtherGroundWater a us_wqp:LocationType ;
    rdfs:label "Other-Ground Water" ;
    rdfs:comment "The water present beneath Earth's surface in soil pore spaces and in the fractures of rock formations."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.OtherSurfaceWater a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Other-Surface Water" ;
    rdfs:comment "water on the surface of continents such as in a river, lake, or wetland."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.PipeUnspecifiedSource a us_wqp:LocationType ;
    rdfs:label "Pipe, Unspecified Source" ;
    rdfs:comment "Methods used to remove already formed contaminants from a stream of air, water, waste, product or similar. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Playa a us_wqp:LocationType ;
    rdfs:label "Playa" ;
    rdfs:comment "Known as an alkali flat or sabkha, a desert basin with no outlet which periodically fills with water to form a temporary lake."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Pond a us_wqp:LocationType ;
    rdfs:label "Pond" ;
    rdfs:comment "Naturally occurring. A pond is an area filled with water, that is smaller than a lake. It may arise naturally in floodplains as part of a river system, or be a somewhat isolated depression (such as a kettle, vernal pool, or prairie pothole)."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.PondAnchialine a us_wqp:LocationType ;
    rdfs:label "Pond-Anchialine" ;
    rdfs:comment "A landlocked body of water with a subterranean connection to the ocean. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.PondSediment a us_wqp:LocationType ;
    rdfs:label "Pond-Sediment" ;
    rdfs:comment "A naturally occurring material that is broken down by processes of weathering and erosion, and is subsequently transported by the action of wind, water, or ice or by the force of gravity acting on the particles."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.PondStock a us_wqp:LocationType ;
    rdfs:label "Pond-Stock" ;
    rdfs:comment "Ponds for a specific purpose for watering livestock."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.PondStormwater a us_wqp:LocationType ;
    rdfs:label "Pond-Stormwater" ;
    rdfs:comment "Stormwater, also spelled storm water, is water that originates during precipitation events and snow/ice melt."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.PondWastewater a us_wqp:LocationType ;
    rdfs:label "Pond-Wastewater" ;
    rdfs:comment "Any water that has been affected by human use. Wastewater is \"used water from any combination of domestic, industrial, commercial or agricultural activities, surface runoff or stormwater, and any sewer inflow or sewer infiltration\"."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Reservoir a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Reservoir" ;
    rdfs:comment "An enlarged natural or artificial lake, pond or impoundment created using a dam or lock to store water."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.RiverStream a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "River/Stream" ;
    rdfs:comment "A body of water with surface water flowing within the bed and banks of a channel."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.RiverStreamEphemeral a us_wqp:LocationType ;
    rdfs:label "River/Stream Ephemeral" ;
    rdfs:comment "A stream that flows only briefly during and following a period of rainfall in the immediate locality"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.RiverStreamIntermittent a us_wqp:LocationType ;
    rdfs:label "River/Stream Intermittent" ;
    rdfs:comment "Mormally cease flowing for weeks or months each year. "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.RiverStreamPerennial a us_wqp:LocationType ;
    rdfs:label "River/Stream Perennial" ;
    rdfs:comment "A stream or river (channel) that has continuous flow in parts of its stream bed all year round during years of normal rainfall."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.RiverineImpoundment a us_wqp:LocationType ;
    rdfs:label "Riverine Impoundment" ;
    rdfs:comment "Impoundments (also known as reservoirs) are artificially created standing water bodies, produced by dams on streams or rivers."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.RiverstreamEffluentDominated a us_wqp:LocationType ;
    rdfs:label "River/stream Effluent-Dominated" ;
    rdfs:comment "A stream or river that gets a significant portion of its flow from effulent discharge."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Seep a us_wqp:LocationType ;
    rdfs:label "Seep" ;
    rdfs:comment "A moist or wet place where water, usually groundwater, reaches the earth's surface from an underground aquifer."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Soilsediment a us_wqp:LocationType ;
    rdfs:label "Soil sediment" ;
    rdfs:comment "The unconsolidated mineral or organic material on the immediate surface of the Earth that serves as a natural medium for the growth of land plants"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.SourceManMade a us_wqp:LocationType ;
    rdfs:label "Source-ManMade" ;
    rdfs:comment "Industrial, agricultural, stormwater, sewer/septic, discharge/pipe, lagoon, or other source"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.SpigotFaucet a us_wqp:LocationType ;
    rdfs:label "Spigot / Faucet" ;
    rdfs:comment "A spigot is a single knob faucet that only has one pipe it controls, like the outdoor spigot that you connect a garden hose to. A tap is used when there isn't a pipe"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Spring a us_wqp:DefWQPGroundWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Spring" ;
    rdfs:comment "the result of an aquifer being filled to the point that the water overflows onto the land surface."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.StateLocalAirMonitoringStation a us_wqp:LocationType ;
    rdfs:label "State/Local Air Monitoring Station" ;
    rdfs:comment "A Facility to measure systematically concentrations of pollutants in ambient air. Synonym: Air quality measurement station."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.StormSewer a us_wqp:LocationType ;
    rdfs:label "Storm Sewer" ;
    rdfs:comment "A system designed to carry rainfall runoff and other drainage."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Subtidal a us_wqp:LocationType ;
    rdfs:label "Subtidal" ;
    rdfs:comment "Refers to the area where the seabed is below the lowest tide"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Sump a us_wqp:LocationType ;
    rdfs:label "Sump" ;
    rdfs:comment "A sump is a shallow borehole (no well construction) that intersects the water table"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.SurveyMonument a us_wqp:LocationType ;
    rdfs:label "Survey Monument" ;
    rdfs:comment "Boundary monuments are placed at every corner of the property, including any angle or change of direction of the boundary line."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.TestPit a us_wqp:LocationType ;
    rdfs:label "Test Pit" ;
    rdfs:comment "A trial pit (or test pit) is an excavation of ground in order to study or sample the composition and structure of the subsurface, usually dug during a site investigation, a soil survey or a geological survey. Trial pits are dug before the construction. They are dug to determine the geology and the water table of that site."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WastePit a us_wqp:LocationType ;
    rdfs:label "Waste Pit" ;
    rdfs:comment "A mud pit in which a supply of drilling fluid has been stored. Also, a waste pit, usually an excavated, earthen-walled pit. It may be lined with plastic to prevent soil contamination."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WasteSewer a us_wqp:LocationType ;
    rdfs:label "Waste Sewer" ;
    rdfs:comment "a waste pipe that carries away sewage or surface water"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.Well a us_wqp:DefWQPGroundWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Well" ;
    rdfs:comment "An excavation or structure created in the ground by digging, driving, or drilling to access liquid resources, usually water."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarineDitch a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Ditch" ;
    rdfs:comment "Open water estuary, bay, sound Vegetated and non-vegetated brackish and saltwater ditch"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarineEmergent a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Emergent" ;
    rdfs:comment "Open water estuary, bay, sound Herbaceous marsh, fen, swale and wet meadow"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarineForested a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Forested" ;
    rdfs:comment "Open water estuary, bay, sound Vegetated brackish and saltwater forest"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarineMarsh a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Marsh" ;
    rdfs:comment "Open water estuary, bay, sound Vegetated brackish and saltwater marsh"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarinePool a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Pool" ;
    rdfs:comment "Open water estuary, bay, sound Vegetated brackish and saltwater pool: lagoons"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarineScrubShrub a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Scrub-Shrub" ;
    rdfs:comment "Open water estuary, bay, sound Vegetated brackish and saltwater scrub-shrub"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandEstuarineTidalCreek a us_wqp:LocationType ;
    rdfs:label "Wetland Estuarine-Tidal Creek" ;
    rdfs:comment "Open water estuary, bay, sound Vegetated brackish and saltwater tidal creek"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandLacustrineAquaticBed a us_wqp:LocationType ;
    rdfs:label "Wetland Lacustrine-Aquatic Bed" ;
    rdfs:comment "Includes nontidal wetlands fringing lakes and dominated by floating leaved and submergent plants"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandLacustrineEmergent a us_wqp:LocationType ;
    rdfs:label "Wetland Lacustrine-Emergent" ;
    rdfs:comment "bounded by upland or by wetland dominated by trees, shrubs, persistent emergents, emergent mosses, or lichens"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandLacustrineUnconsolidatedBottom a us_wqp:LocationType ;
    rdfs:label "Wetland Lacustrine-Unconsolidated Bottom" ;
    rdfs:comment "Includes nontidal wetlands ringing lakes in which substrate is at least 25% particles smaller than stones and vegetative cover less than 30%"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandPalustrineEmergent a us_wqp:LocationType ;
    rdfs:label "Wetland Palustrine-Emergent" ;
    rdfs:comment "includes all nontidal wetlands characterized by erect, rooted, herbaceous hydrophytes, excluding mosses and lichens and all such wetlands that occur in tidal areas where salinity due to ocean-derived salts is below 0.5 ‰"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandPalustrineForested a us_wqp:LocationType ;
    rdfs:label "Wetland Palustrine-Forested" ;
    rdfs:comment "includes all nontidal wetlands dominated by trees, forest, and all such wetlands that occur in tidal areas where salinity due to ocean-derived salts is below 0.5 ‰"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandPalustrineMossLichen a us_wqp:LocationType ;
    rdfs:label "Wetland Palustrine-Moss-Lichen" ;
    rdfs:comment "includes all nontidal wetlands dominated by mosses or lichens, and all such wetlands that occur in tidal areas where salinity due to ocean-derived salts is below 0.5 ‰"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandPalustrinePond a us_wqp:LocationType ;
    rdfs:label "Wetland Palustrine Pond" ;
    rdfs:comment "includes all nontidal wetlands dominated by pond and all such wetlands that occur in tidal areas where salinity due to ocean-derived salts is below 0.5 ‰"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandPalustrineShrubScrub a us_wqp:LocationType ;
    rdfs:label "Wetland Palustrine-Shrub-Scrub" ;
    rdfs:comment "includes all nontidal wetlands dominated by, shrubs, scrub and all such wetlands that occur in tidal areas where salinity due to ocean-derived salts is below 0.5 ‰"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandRiverineAquaticBed a us_wqp:LocationType ;
    rdfs:label "Wetland Riverine-Aquatic Bed" ;
    rdfs:comment "Includes wetlands connected by or within low gradient rivers dominated by floating leaved and submergent plants "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandRiverineEmergent a us_wqp:LocationType ;
    rdfs:label "Wetland Riverine-Emergent" ;
    rdfs:comment "wetlands connected by rivers. ... They are found along the edges of rivers, streams and creeks and include rivers, floodplains, marshes, lakes and billabongs. characterized by erect, rooted, herbaceous hydrophytes, excluding mosses and lichens"^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandRiverineUnconsolidatedBottom a us_wqp:LocationType ;
    rdfs:label "Wetland Riverine-Unconsolidated Bottom" ;
    rdfs:comment "Includes nontidal wetlands connected by rivers in which substrate is at least 25% particles smaller than stones and vegetative cover less than 30%  "^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp:featureType.WetlandUndifferentiated a us_wqp:DefWQPSurfaceWaterFeatureType,
        us_wqp:LocationType ;
    rdfs:label "Wetland Undifferentiated" ;
    rdfs:comment "a land area that is saturated with water, either permanently or seasonally, It primarily is characteristized by vegetation of aquatic plants, adapted to the unique hydric soil."^^xsd:string ;
    rdfs:isDefinedBy us_wqp_cv:monitoring_location_type .

us_wqp_cv:monitoring_location_type a owl:Ontology ;
    dcterms:description "This ontology contains the controlled vocabulary for Monitoring Location Type from the Water Quality Portal"^^xsd:string ;
    dcterms:modified "2026-04-22"^^xsd:date ;
    dcterms:title "WQP Controlled Vocabulary - Monitoring Location Type"^^xsd:string .

