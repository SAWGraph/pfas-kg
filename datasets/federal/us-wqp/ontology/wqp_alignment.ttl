@prefix owl: <http://www.w3.org/2002/07/owl#> .

<http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment> rdf:type owl:Ontology ;
                                        dcterms:contributor <http://orcid.org/0000-0002-5331-5052> ,
                                                            <http://orcid.org/0000-0003-3547-8058> ,
                                                            <https://orcid.org/0000-0003-3271-6700>,
                                                            <https://orcid.org/0000-0002-9070-3169> ;
                                        dcterms:created "2025-08-07" ;
                                        dcterms:creator <http://orcid.org/0000-0002-5331-5052> ,
                                                        <https://orcid.org/0000-0003-3271-6700>;
                                        dcterms:description "This ontology supports SAWGraph"@en ;
                                        dcterms:title "Ontology for US Water Quality Portal data - alignment controlled vocabulary to reference ontologies"@en ;
                                        owl:versionInfo "1.0"@en .

