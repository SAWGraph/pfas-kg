    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

# sample type by media 
us_wqp:DefWQPWaterSample rdf:type owl:Restriction;
        owl:onProperty coso:sampleOfMaterialType;
        owl:hasValue us_wqp_data:sampleMedia.water; 
        rdfs:subClassOf coso:WaterSample;
        rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.
    
us_wqp:DefWQPSoilSample rdf:type owl:Restriction;
        owl:onProperty coso:sampleOfMaterialType;
        owl:hasValue us_wqp_data:sampleMedia.soil; 
    rdfs:subClassOf coso:SoilSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPSedimentSample rdf:type owl:Restriction;
        owl:onProperty coso:sampleOfMaterialType;
        owl:hasValue us_wqp_data:sampleMedia.sediment; 
    rdfs:subClassOf coso:SedimentSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPBiologicalSample rdf:type owl:Restriction;
        owl:onProperty coso:sampleOfMaterialType;
        owl:hasValue us_wqp_data:sampleMedia.biological; 
    rdfs:subClassOf coso:BiotaSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPTissueSample rdf:type owl:Restriction;
        owl:onProperty coso:sampleOfMaterialType;
        owl:hasValue us_wqp_data:sampleMedia.tissue; 
    rdfs:subClassOf coso:AnimalTissueSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPAirSample rdf:type owl:Restriction;
        owl:onProperty coso:sampleOfMaterialType;
        owl:hasValue us_wqp_data:sampleMedia.air; 
    rdfs:subClassOf coso:AirSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

# monitoring location feature type mapping 

us_wqp:DefWQPSurfaceWaterFeatureType rdf:type owl:Class;
    rdfs:subClassOf us_wqp:LocationType;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPGroundWaterFeatureType rdf:type owl:Class;
    rdfs:subClassOf us_wqp:LocationType;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPWasteWaterFeatureType rdf:type owl:Class;
      rdfs:subClassOf us_wqp:LocationType;
      rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

#Water material samples by source mapping using activity media and monitoring location
  
us_wqp:DefWQPSampleFromSurfaceWaterFeature rdf:type owl:Restriction;
        owl:onProperty coso:sampleFeatureType;
        owl:someValuesFrom us_wqp:DefWQPSurfaceWaterFeatureType;
        rdfs:subClassOf us_wqp:Sample;
        rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPSampleFromGroundWaterFeature rdf:type owl:Restriction;
        owl:onProperty coso:sampleFeatureType;
        owl:someValuesFrom us_wqp:DefWQPGroundWaterFeatureType;
        rdfs:subClassOf us_wqp:Sample;
        rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.

us_wqp:DefWQPSurfaceWaterSample rdf:type owl:Class;
    owl:intersectionOf (us_wqp:DefWQPWaterSample us_wqp:DefWQPSampleFromSurfaceWaterFeature); 
    rdfs:subClassOf coso:SurfaceWaterSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>. 

us_wqp:DefWQPGroundWaterSample rdf:type owl:Class;
    owl:intersectionOf(us_wqp:DefWQPWaterSample us_wqp:DefWQPSampleFromGroundWaterFeature);
    rdfs:subClassOf coso:GroundWaterSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>. 

us_wqp:DefWQPWasteWaterSample rdf:type owl:Class;
    owl:intersectionOf (us_wqp:DefWQPWaterSample [rdf:type owl:Restriction;
    owl:onProperty coso:sampleFeatureType;
    owl:someValuesFrom us_wqp:DefWQPWasteWaterFeatureType]);
    rdfs:subClassOf coso:WasteWaterSample;
    rdfs:isDefinedBy <http://w3id.org/sawgraph/v1/us-wqp/controlledVocab/wqp-alignment>.
